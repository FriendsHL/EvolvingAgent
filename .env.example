# Evolving Agent — environment template
# Copy to `.env` (gitignored) and fill in the values you need.
# The web server loads `.env` at startup via Node 20.6+'s built-in
# `process.loadEnvFile` — no dotenv package needed.

# ============================================================
# LLM provider selection
# ============================================================
# Pick ONE preset. SessionManager calls LLMProvider.fromEnv() which
# reads EVOLVING_AGENT_PROVIDER first, then falls back to API-key
# auto-detection (DASHSCOPE > OPENAI > ANTHROPIC).
#
# Available presets (see packages/core/src/llm/provider.ts):
#   anthropic       Claude (claude-sonnet-4-20250514 / claude-haiku)
#   openai          GPT (gpt-4o / gpt-4o-mini)
#   bailian         Qwen-plus via DashScope compatible mode
#   bailian-coding  qwen3-coder-plus + glm-5 (recommended for coding)
#   bailian-glm5    glm-5 across all roles
#   deepseek        deepseek-chat
EVOLVING_AGENT_PROVIDER=bailian-coding

# ============================================================
# API keys — only set the ones for the provider(s) you use
# ============================================================
# DashScope (百炼) — required for bailian / bailian-coding / bailian-glm5
DASHSCOPE_API_KEY=

# Anthropic — required for `anthropic` preset
ANTHROPIC_API_KEY=

# OpenAI — required for `openai` preset
OPENAI_API_KEY=

# DeepSeek — required for `deepseek` preset
DEEPSEEK_API_KEY=

# ============================================================
# Web server
# ============================================================
# EA_WEB_PORT=3721
# EA_DATA_PATH=data/memory

# ============================================================
# Feishu channel (optional — leave blank to disable)
# ============================================================
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=
# FEISHU_BOT_OPEN_ID=

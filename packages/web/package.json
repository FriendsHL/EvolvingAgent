{
  "name": "@evolving-agent/web",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch src/server/index.ts\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsup src/server/index.ts --format esm --outDir dist/server",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@evolving-agent/core": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "hono": "^4.7.0",
    "nanoid": "^5.1.0",
    "playwright": "^1.59.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.5.0",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0"
  }
}
